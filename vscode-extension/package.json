{
  "name": "sqlserver-mcp-helper",
  "displayName": "SQL Server MCP Helper",
  "description": "Convenience commands for installing and managing SQL Server MCP in VS Code user profile.",
  "version": "0.2.4",
  "publisher": "kingsnow129",
  "repository": {
    "type": "git",
    "url": "https://github.com/kingsnow129/sqlserver-mcp"
  },
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sqlserverMcp.installUser",
        "title": "SQLServer MCP: Install Or Update (User)"
      },
      {
        "command": "sqlserverMcp.openEnv",
        "title": "SQLServer MCP: Open Env"
      },
      {
        "command": "sqlserverMcp.openMcpListServers",
        "title": "SQLServer MCP: Open MCP Server List"
      },
      {
        "command": "sqlserverMcp.openUserMcpConfig",
        "title": "SQLServer MCP: Open User MCP Configuration"
      }
    ]
  },
  "scripts": {
    "package": "npx @vscode/vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.0"
  }
}
