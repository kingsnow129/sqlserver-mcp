{
  "name": "database-mcp-helper",
  "displayName": "Database MCP Helper",
  "description": "Install, manage, and uninstall user-level Database MCP profiles in VS Code.",
  "version": "0.3.0",
  "publisher": "kingsnow129",
  "repository": {
    "type": "git",
    "url": "https://github.com/kingsnow129/sqlserver-mcp"
  },
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sqlserverMcp.uninstallUser",
        "title": "Database MCP: Uninstall (User)"
      },
      {
        "command": "sqlserverMcp.manageAliases",
        "title": "Database MCP: Manage Databases"
      },
      {
        "command": "sqlserverMcp.openMcpListServers",
        "title": "Database MCP: Open MCP Server List"
      }
    ]
  },
  "scripts": {
    "package": "npx @vscode/vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.0"
  }
}
