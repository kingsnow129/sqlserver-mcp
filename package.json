{
  "name": "@kingsnow129/sqlserver-mcp",
  "version": "0.2.4",
  "mcpName": "io.github.kingsnow129/sqlserver-mcp",
  "description": "MCP server for SQL Server operations (connect, query, schema introspection)",
  "author": "kingsnow129",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "sqlserver-mcp": "dist/server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kingsnow129/sqlserver-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/kingsnow129/sqlserver-mcp/issues"
  },
  "homepage": "https://github.com/kingsnow129/sqlserver-mcp#readme",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepare": "npm run build",
    "start": "node dist/server.js",
    "dev": "node src/server.js",
    "pack:check": "npm run build && npm pack --dry-run"
  },
  "keywords": [
    "mcp",
    "sqlserver",
    "database"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^16.4.5",
    "mssql": "^11.0.1"
  }
}
